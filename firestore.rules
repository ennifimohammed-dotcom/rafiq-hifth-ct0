rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Teacher private data: only the authenticated teacher can read/write
    match /teachers/{teacherId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == teacherId;
    }

    // Share token registry: teacher-only
    match /shared_tokens/{token} {
      allow read, delete: if request.auth != null && resource.data.teacherId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
    }

    // Public read-only report snapshots (what parents see)
    match /public_reports/{token} {
      allow read: if true;
      allow create, update: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.teacherId == request.auth.uid;
    }
  }
}
